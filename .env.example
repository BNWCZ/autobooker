APP_URL=https://doorjames.app
DOORJAMES_USERNAME=your.email@company.com
DOORJAMES_PASSWORD=yourpassword
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN
SESSION_STATE_PATH=session/state.json
BOOKINGS_PATH=bookings.csv
GOOGLE_CALENDAR_ID=your.email@gmail.com
GOOGLE_SERVICE_ACCOUNT_PATH=service_account.json

# Comma-separated substrings to match against calendar event titles (case-insensitive)
# Events containing any of these patterns count as remote working days (no desk booking)
REMOTE_WORKING_PATTERNS=

# Events containing any of these patterns count as out-of-office days (no booking, cancel if exists)
OUT_OF_OFFICE_PATTERNS=

# Discord bot token and command channel ID for skip commands (optional)
# Create a bot at https://discord.com/developers/applications with Read Messages + Manage Messages permissions
# Supported commands (sent as plain messages in the command channel):
#   skip  — skip the next automated action for today (check-in or cancellation)
DISCORD_BOT_TOKEN=
DISCORD_COMMAND_CHANNEL_ID=
